#!/usr/bin/env bash
# pre-commit: 阻止含真实密钥特征的文件进入 git 历史
set -eu

RED='\033[0;31m'; YELLOW='\033[1;33m'; NC='\033[0m'
FOUND=0

# ── 1. 阻止 .env 文件被 stage ─────────────────────────────────────────────
ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)\.env($|\.)' || true)
if [[ -n "$ENV_FILES" ]]; then
  echo -e "${RED}[pre-commit] ❌ .env 文件被 stage，已阻止提交${NC}"
  echo "$ENV_FILES" | while read -r f; do echo "   → $f"; done
  FOUND=1
fi

# ── 2. 用 Python 扫描 staged diff 中的高置信度密钥特征 ────────────────────
SCAN_RESULT=$(git diff --cached -U0 | python3 - <<'PYEOF'
import sys, re

PATTERNS = [
    (r'sk-[a-zA-Z0-9]{20,}',                       'OpenAI/通义 API Key'),
    (r'tvly-[a-zA-Z0-9]{20,}',                     'Tavily API Key'),
    (r'AIza[a-zA-Z0-9_\-]{30,}',                   'Google API Key'),
    (r'ghp_[a-zA-Z0-9]{36,}',                      'GitHub PAT'),
    (r'xoxb-\d+-\d+-[a-zA-Z0-9]+',                 'Slack Bot Token'),
    (r'AKIA[0-9A-Z]{16}',                           'AWS Access Key ID'),
    (r'-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY',    'Private Key'),
]

# 明确的误报白名单（测试用占位符）
WHITELIST = re.compile(
    r'INVALID_KEY_FOR_TEST|test-api-key|your_api_key|placeholder|example|dummy|fake',
    re.IGNORECASE,
)

hits = []
for line in sys.stdin:
    if not line.startswith('+') or line.startswith('+++'):
        continue
    if WHITELIST.search(line):
        continue
    for pattern, label in PATTERNS:
        m = re.search(pattern, line)
        if m:
            masked = m.group()[:8] + '...'
            hits.append(f'{label}: {masked}')

for h in hits:
    print(h)
PYEOF
)

if [[ -n "$SCAN_RESULT" ]]; then
  echo -e "${RED}[pre-commit] ❌ 检测到疑似密钥特征，已阻止提交：${NC}"
  echo "$SCAN_RESULT" | while read -r m; do echo "   → $m"; done
  echo ""
  echo "   如确认为误报，可用：git commit --no-verify"
  FOUND=1
fi

# ── 3. 警告：代码中含不在白名单内的硬编码密码字面量 ──────────────────────
PASSWD_RESULT=$(git diff --cached -U0 | python3 - <<'PYEOF'
import sys, re

# 匹配 password = "xxx" / password: "xxx" 且值不是明显占位符
PAT = re.compile(r'password\s*[:=]\s*["\047]([^"\047\$\{<>\s]{6,})["\047]', re.I)
OK  = re.compile(r'neo4jpassword|your_password|test|example|placeholder|localhost|dummy', re.I)

for line in sys.stdin:
    if not line.startswith('+') or line.startswith('+++'):
        continue
    m = PAT.search(line)
    if m and not OK.search(line):
        print(line.rstrip())
PYEOF
)

if [[ -n "$PASSWD_RESULT" ]]; then
  echo -e "${YELLOW}[pre-commit] ⚠️  代码中含疑似硬编码密码，请确认是占位符：${NC}"
  echo "$PASSWD_RESULT" | head -5 | while read -r l; do echo "   $l"; done
  echo "   如确认安全，用：git commit --no-verify"
  FOUND=1
fi

[[ $FOUND -eq 1 ]] && exit 1 || exit 0
